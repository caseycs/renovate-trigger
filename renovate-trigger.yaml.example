# All configuration is via environment variables.
# This file is a reference — not loaded by the app.

# RT_LISTEN_ADDR=:8080                    # HTTP listen address (default: :8080)
# RT_LOG_LEVEL=info                       # debug | info | warn | error (default: info)
# RT_WEBHOOK_SECRET=<secret>              # GitHub webhook secret (required)
# RT_BATCH_WINDOW_SECONDS=30              # Batch collection window (default: 30)
# RT_CRONJOB_NAME=renovate                # Source CronJob name (required)
# RT_CRONJOB_NAMESPACE=renovate           # Source CronJob namespace (required)
# RT_REPOS=org/repo-a,org/repo-b          # Comma-separated allowlist (empty = accept all)
