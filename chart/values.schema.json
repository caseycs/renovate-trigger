{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["image", "config", "existingSecret"],
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"],
          "default": "IfNotPresent"
        }
      }
    },
    "config": {
      "type": "object",
      "required": ["cronjob"],
      "properties": {
        "listenAddr": {
          "type": "string",
          "default": ":8080"
        },
        "logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info"
        },
        "batchWindowSeconds": {
          "type": "integer",
          "minimum": 1,
          "default": 30
        },
        "cronjob": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "namespace": {
              "type": "string",
              "description": "Source CronJob namespace. Defaults to the release namespace."
            }
          }
        }
      }
    },
    "existingSecret": {
      "type": "object",
      "description": "Existing Secret (e.g. managed by External Secrets Operator) holding the App credentials. The chart does not create it.",
      "required": ["name", "clientIdKey", "privateKeyKey", "webhookSecretKey"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Name of the existing Secret."
        },
        "clientIdKey": {
          "type": "string",
          "minLength": 1,
          "description": "Key holding the GitHub App client ID."
        },
        "privateKeyKey": {
          "type": "string",
          "minLength": 1,
          "description": "Key holding the GitHub App private key (PEM)."
        },
        "webhookSecretKey": {
          "type": "string",
          "minLength": 1,
          "description": "Key holding the webhook secret."
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean",
          "default": true
        },
        "name": {
          "type": "string"
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "default": "ClusterIP"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 8080
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "host": { "type": "string" },
        "path": { "type": "string", "default": "/webhook" },
        "pathType": {
          "type": "string",
          "enum": ["Prefix", "Exact", "ImplementationSpecific"],
          "default": "Prefix"
        },
        "tls": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "secretName": { "type": "string" }
          }
        }
      }
    },
    "ingressRoute": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "entryPoint": { "type": "string", "default": "websecure" },
        "host": { "type": "string" },
        "pathPrefix": { "type": "string", "default": "/webhook" },
        "labels": { "type": "object" },
        "tls": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "secretName": { "type": "string" }
          }
        }
      }
    },
    "extraObjects": {
      "type": "array",
      "description": "Additional Kubernetes objects to create",
      "items": {
        "type": "object"
      },
      "default": []
    }
  }
}
